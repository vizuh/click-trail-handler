    "tag": [
      {
        "tagId": "1",
        "accountId": "0",
        "containerId": "0",
        "name": "Consent Mode — Defaults",
        "type": "html",
        "parameter": [
          {
            "type": "TEMPLATE",
            "key": "html",
            "value": "<script>\nwindow.dataLayer = window.dataLayer || [];\nfunction gtag(){dataLayer.push(arguments);}\ngtag('consent', 'default', {\n  'ad_storage': 'denied',\n  'analytics_storage': 'denied',\n  'ad_user_data': 'denied',\n  'ad_personalization': 'denied',\n  'wait_for_update': 500\n});\ngtag('set', 'ads_data_redaction', true);\ngtag('set', 'url_passthrough', true);\n</script>"
          },
          { "type": "BOOLEAN", "key": "supportDocumentWrite", "value": "false" }
        ],
        "firingTriggerId": ["2"],
        "parentFolderId": "3",
        "notes": "Sets consent defaults before any other tags fire. Adjust defaults to match your CMP. ClickTrail updates consent via the Consent Bridge."
